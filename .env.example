# Copie ce fichier en `.env` et renseigne ta clé. NE COMMITTE JAMAIS `.env`.

# Clé API Nuthatch (https://nuthatch.lastelm.software/getKey.html)
NUTHATCH_API_KEY=ta_cle_ici

# Port d'écoute du serveur
PORT=3000

# Filtre de région : on ne garde que les oiseaux dont au moins une région
# contient cette chaîne (insensible à la casse). Ex : "europe", "north america".
REGION_FILTER=europe

# Durée de vie du cache des oiseaux en heures (rafraîchi automatiquement)
CACHE_TTL_HOURS=12
